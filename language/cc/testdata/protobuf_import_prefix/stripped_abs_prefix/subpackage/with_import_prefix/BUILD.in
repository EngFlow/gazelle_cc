load("@com_google_protobuf//bazel:cc_proto_library.bzl", "cc_proto_library")
load("@rules_proto//proto:defs.bzl", "proto_library")

# gazelle:proto_import_prefix proto

proto_library(
    name = "d_proto",
    srcs = ["d.proto"],
    import_prefix = "proto",
    visibility = ["//visibility:public"],
)

cc_proto_library(
    name = "d_cc_proto",
    visibility = ["//visibility:public"],
    deps = [":d_proto"],
)
