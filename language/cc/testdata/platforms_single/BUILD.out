load("@rules_cc//cc:defs.bzl", "cc_library")

# gazelle:cc_platform linux x86_64 @platforms//os:linux

cc_library(
    name = "my_library",
    srcs = ["my_library.cc"],
    implementation_deps = select({
        "@platforms//os:linux": [
            "//lib",
        ],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)
